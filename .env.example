# =============================================================================
# Foot Traffic Analyzer - Environment Variables
#
# EVERYTHING is provisioned by Bicep via `azd up` — you do NOT need to
# pre-create Azure OpenAI or Synapse. Bicep creates them automatically.
#
# The only things you need to provide upfront are:
#   1. Your Azure subscription/location (azd handles this interactively)
#   2. Optional: custom video feed URLs
#   3. Optional: override the GPT-4o model version or deployment name
#
# Recommended workflow:
#   azd up          ← provisions everything + deploys apps in one command
#   azd env list    ← see all values (including auto-generated ones)
#   azd down        ← tear down all resources
#
# azd stores its environment in .azure/<env-name>/.env (gitignored).
# NEVER commit .env or .azure/ to source control.
# =============================================================================

# ─── azd Core (set interactively by `azd up`, or override here) ──────────────
AZURE_ENV_NAME=prod
AZURE_LOCATION=eastus
# Region for Azure OpenAI / Cognitive Services (separate from AZURE_LOCATION).
# Defaults to eastus2 — override if you need a different region for model availability.
AZURE_COGNITIVE_SERVICES_LOCATION=eastus2
# AZURE_SUBSCRIPTION_ID and AZURE_TENANT_ID are set by `azd auth login`

# ─── Video Feed URLs (optional) ──────────────────────────────────────────────
# Comma-separated list of public video feed URLs to monitor.
# Defaults to 5 TfL JamCam feeds across central London.
# Supports: TfL JamCam MP4/JPEG, RTSP, HLS (.m3u8), direct video URLs.
#
# To override:  azd env set VIDEO_FEED_URLS "https://..."
VIDEO_FEED_URLS=https://s3-eu-west-1.amazonaws.com/jamcams.tfl.gov.uk/00001.07450.mp4,https://s3-eu-west-1.amazonaws.com/jamcams.tfl.gov.uk/00001.08858.mp4,https://s3-eu-west-1.amazonaws.com/jamcams.tfl.gov.uk/00001.08750.mp4

# ─── OpenAI Model Settings (optional overrides) ──────────────────────────────
# The Azure OpenAI account and GPT-4o deployment are created by Bicep.
# Override these only if you need a different model version or capacity.
AZURE_OPENAI_MODEL_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_MODEL_VERSION=2024-05-13

# ─── Analysis Tuning (optional) ──────────────────────────────────────────────
FRAMES_PER_INTERVAL=5
MAX_PERSONS_PER_FRAME=20
CONFIDENCE_THRESHOLD=0.6

# ─── Startup Reprocessing (optional) ─────────────────────────────────────────
# On container restart, frames that previously returned 0 people detected are
# re-analyzed so improvements to the VLM model/prompt benefit past data.
# Set REPROCESS_MAX_FRAMES=0 to disable reprocessing entirely.
REPROCESS_MAX_FRAMES=50
REPROCESS_LOOKBACK_DAYS=7

# ─── Auto-populated by Bicep after `azd provision` ───────────────────────────
# These are written to .azure/<env>/.env automatically — do NOT set manually.
# Listed here for reference only.
#
# AZURE_RESOURCE_GROUP              = foot-traffic-rg-<suffix>
# AZURE_OPENAI_ENDPOINT             = https://foottraffic-oai-<suffix>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME      = gpt-4o
# AZURE_SYNAPSE_WORKSPACE_NAME      = foottraffic-synapse-<suffix>
# AZURE_SYNAPSE_SQL_POOL_NAME       = foottrafficdw
# AZURE_KEY_VAULT_NAME              = foottraffic-kv-<suffix>
# AZURE_STORAGE_ACCOUNT_NAME        = foottraffic<suffix>
# AZURE_CONTAINER_REGISTRY_NAME     = foottrafficacr<suffix>
# SERVICE_STREAMLIT_DASHBOARD_URI   = https://foottraffic-ca-<suffix>.<region>.azurecontainerapps.io
#
# Secrets (stored in Key Vault, never exposed as plain env vars in production):
#   openai-api-key        → auto-populated from provisioned OpenAI account
#   synapse-sql-password  → auto-generated by Bicep (deterministic, idempotent)
#   servicebus-connection-string → auto-populated from provisioned Service Bus

# ─── GitHub Actions Secrets (for CI/CD) ──────────────────────────────────────
# Only AZURE_CREDENTIALS is required for CI/CD — everything else is provisioned.
#
# AZURE_CREDENTIALS — Service principal JSON:
#   az ad sp create-for-rbac \
#     --name "foot-traffic-cicd" \
#     --role contributor \
#     --scopes /subscriptions/YOUR_SUB_ID \
#     --sdk-auth
#
# Optional CI/CD overrides (same as above):
#   VIDEO_FEED_URLS
