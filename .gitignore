# =============================================================================
# Foot Traffic Analyzer - .gitignore
# =============================================================================

# ─── Secrets & Environment ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.pfx
.deployment-outputs.json

# ─── Azure Developer CLI (azd) ───────────────────────────────────────────────
# .azure/ contains environment state including secrets — never commit it.
# Commit azure.yaml (the manifest) but NOT the .azure/ directory.
.azure/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.python_packages/

# ─── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env/

# ─── Azure Functions ─────────────────────────────────────────────────────────
functions/.python_packages/
functions/local.settings.json
functions.zip

# ─── Streamlit ───────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ─── Docker ──────────────────────────────────────────────────────────────────
*.tar

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Temporary files ─────────────────────────────────────────────────────────
*.tmp
*.temp
/tmp/

# ─── Bicep compiled ARM templates ────────────────────────────────────────────
infrastructure/*.json
!infrastructure/main.parameters.json
